---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header class="bg-white shadow-md">
	<nav class="container mx-auto px-4 py-3 flex items-center justify-between">
		<div class="flex items-center space-x-3">
			<div class="bg-orange-600 text-white font-bold p-2 rounded-lg text-xl">İYİ</div>
			<h2 class="text-xl font-black tracking-tighter m-0 uppercase">
				<a href="/" class="text-slate-900 no-underline hover:text-orange-600 transition-colors">iyibilgilernet</a>
			</h2>
		</div>
		<div class="hidden md:flex space-x-6 font-semibold">
			<HeaderLink href="/" class="hover:text-orange-600">Ana Sayfa</HeaderLink>
			<HeaderLink href="/blog" class="hover:text-orange-600">Tarifler</HeaderLink>
			<HeaderLink href="/about" class="hover:text-orange-600">Hakkımızda</HeaderLink>
		</div>
		<div class="flex space-x-4">
			<a href="https://youtube.com/@iyibilgilernet" target="_blank" class="text-red-600 text-2xl hover:scale-110 transition-transform">🔴</a>
			<a href="https://tiktok.com/@iyibilgilernet" target="_blank" class="text-black text-2xl hover:scale-110 transition-transform">📱</a>
		</div>
	</nav>
</header>
