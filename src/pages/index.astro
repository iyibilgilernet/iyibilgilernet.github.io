---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="tr">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style is:global>
	/* Tarayıcının tüm inatçı büyük ayarlarını sıfırlıyoruz */
	html, body, main, article, div, h1, h2, h3, p, span {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	/* Senin istediğin o zarif ve küçük puntolar */
	h1 { 
		font-size: 18px !important; 
		color: #ea580c !important; 
		line-height: 1.2 !important;
		margin-bottom: 14px !important;
	}
	h2 { 
		font-size: 16px !important; 
		color: #334155 !important; 
		margin-bottom: 12px !important;
	}
	h3 { 
		font-size: 6px !important; 
		color: #1e293b !important; 
		font-weight: bold !important;
		margin-bottom: 8px !important;
	}
	
	/* Video başlıkları için ekstra minyatür ayar */
	.video-kart h3 {
		font-size: 6px !important; 
		text-transform: uppercase;
		letter-spacing: 0.5px;
	}

	/* Normal metinler */
	p, li, span { 
		font-size: 13px !important; 
		line-height: 1.5 !important;
		color: #475569 !important;
	}

	/* Video kutusunu biraz daraltalım ki yazılarla uyumlu olsun */
	.video-kart {
		padding: 8px !important;
		border-radius: 8px !important;
	}
</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="video-vitrini">
				<div class="video-kart">
					<h3 style="margin-bottom: 6px;">Çamaşır Makinesi Su Boşaltmıyor mu? 🛠️HEMEN Servis Çağırma</h3>
					<iframe 
						src="https://www.youtube.com/embed/XJAvN4_q1uY" 
						title="Çamaşır Makinesi Su Boşaltmıyor mu? 🛠️HEMEN Servis Çağırma" 
						frameborder="0" 
						allowfullscreen>
					</iframe>
				</div>

				<div class="video-kart">
					<h3 style="margin-bottom: 6px;">🍚 Ekşi Yoğurtları Atmayalım</h3>
					<iframe 
						src="https://www.youtube.com/embed/ZuRrZ1Q-f3I" 
						title="Ekşi Yoğurttan Süzme Yoğurt elde etme" 
						frameborder="0" 
						allowfullscreen>
					</iframe>
				</div>
			</section>

			<article class="prose">
				<h1>Hoş Geldiniz!</h1>
				<p><strong>iyibilgilernet</strong> platformunda en pratik bilgiler ve en lezzetli tarifler sizi bekliyor.</p>
			</article>
		</main>
		<Footer />
	</body>
</html>
