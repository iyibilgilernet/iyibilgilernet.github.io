---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="tr">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style is:global>
	/* Başlıklar - Ne çok büyük ne çok küçük */
	h1 { 
		font-size: 24px !important; /* Ana başlık: Net ve belirgin */
		color: #ea580c !important; 
		margin-bottom: 12px !important;
		font-weight: 800 !important;
	}
	h2 { 
		font-size: 20px !important; /* Alt başlıklar */
		color: #334155 !important; 
		margin-bottom: 10px !important;
	}
	h3 { 
		font-size: 16px !important; /* Video başlıkları ve küçük bölümler */
		color: #1e293b !important; 
		margin-bottom: 6px !important;
	}
	
	/* Video kartı içindeki yazıların özel ayarı */
	.video-kart h3 {
		font-size: 15px !important; /* Videonun üstündeki yazı okunaklı olsun */
		line-height: 1.3 !important;
	}

	/* Okuma metni (Puntolar burasıdır) */
	p, li, span { 
		font-size: 16px !important; /* Standart okuma boyutu budur */
		line-height: 1.6 !important;
		color: #444 !important;
	}

	/* Video kutularına biraz nefes aldıralım */
	.video-kart {
		padding: 12px !important;
		background: #fff;
		border: 1px solid #e2e8f0;
		border-radius: 12px !important;
		transition: transform 0.2s;
	}
	.video-kart:hover {
		transform: translateY(-3px); /* Mouse ile üzerine gelince hafif kalkar */
	}
</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="video-vitrini">

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 30px; padding: 40px 0;">
    
    <div class="video-kart">
       https://www.youtube.com/embed/XJAvN4_q1uY
        <h3>Çamaşır Makinesi Su Boşaltmıyor mu? 🛠️HEMEN Servis Çağırma</h3>
    </div>

    <div class="video-kart">
       https://www.youtube.com/embed/ZuRrZ1Q-f3I
        <h3>Ekşi Yoğurtları Atmayalım</h3>
    </div>

</div>





				<div class="video-kart">
					<h3 style="margin-bottom: 6px;">Çamaşır Makinesi Su Boşaltmıyor mu? 🛠️HEMEN Servis Çağırma</h3>
					<iframe 
						src="https://www.youtube.com/embed/XJAvN4_q1uY" 
						title="Çamaşır Makinesi Su Boşaltmıyor mu? 🛠️HEMEN Servis Çağırma" 
						frameborder="0" 
						allowfullscreen>
					</iframe>
				</div>

				<div class="video-kart">
					<h3 style="margin-bottom: 6px;">🍚 Ekşi Yoğurtları Atmayalım</h3>
					<iframe 
						src="https://www.youtube.com/embed/ZuRrZ1Q-f3I" 
						title="Ekşi Yoğurttan Süzme Yoğurt elde etme" 
						frameborder="0" 
						allowfullscreen>
					</iframe>
				</div>
			</section>

			<article class="prose">
				<h1>Hoş Geldiniz!</h1>
				<p><strong>iyibilgilernet</strong> platformunda en pratik bilgiler ve en lezzetli tarifler sizi bekliyor.</p>
			</article>
		</main>
		<Footer />
	</body>
</html>
