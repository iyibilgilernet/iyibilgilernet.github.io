---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="tr">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 960px;
				margin: auto;
				padding: 3em 1em;
			}
			.video-vitrini {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 2rem;
				margin-bottom: 3rem;
			}
			@media (max-width: 720px) {
				.video-vitrini {
					grid-template-columns: 1fr;
				}
			}
			.video-kart {
				background: white;
				padding: 1rem;
				border-radius: 1rem;
				box-shadow: 0 4px 15px rgba(0,0,0,0.1);
				border-top: 5px solid #ea580c;
			}
			iframe {
				width: 100%;
				aspect-ratio: 16 / 9;
				border-radius: 0.5rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="video-vitrini">
				<div class="video-kart">
					<h3 style="margin-bottom: 10px;">🔥 Nefis Kestane Kebap</h3>
					<iframe 
						src="https://www.youtube.com/embed/VİDEO_ID_BURAYA" 
						title="Kestane Pişirme" 
						frameborder="0" 
						allowfullscreen>
					</iframe>
				</div>

				<div class="video-kart">
					<h3 style="margin-bottom: 10px;">🍚 Tane Tane Pirinç Pilavı</h3>
					<iframe 
						src="https://www.youtube.com/embed/ZuRrZ1Q-f3I" 
						title="Pirinç Pilavı Tarifi" 
						frameborder="0" 
						allowfullscreen>
					</iframe>
				</div>
			</section>

			<article class="prose">
				<h1>Hoş Geldiniz!</h1>
				<p><strong>iyibilgilernet</strong> platformunda en pratik bilgiler ve en lezzetli tarifler sizi bekliyor.</p>
			</article>
		</main>
		<Footer />
	</body>
</html>
